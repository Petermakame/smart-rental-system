<!DOCTYPE html>
<html lang="sw">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
</head>
<body>
  <%- include('../partials/sidebar', { user, activePage: 'dashboard' }) %>
  <div class="main-content">
    <%- include('../partials/topbar', { user, title: 'Dashboard' }) %>

    <div class="content-area">
      <!-- Stats Cards -->
      <div class="stats-grid">
        <div class="stat-card stat-blue">
          <div class="stat-icon"><i class="fas fa-users"></i></div>
          <div class="stat-info">
            <h3><%= stats.totalTenants %></h3>
            <p>Jumla ya Wapangaji</p>
          </div>
        </div>
        <div class="stat-card stat-green">
          <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
          <div class="stat-info">
            <h3><%= stats.paidThisMonth %></h3>
            <p>Waliolipa Mwezi Huu</p>
          </div>
        </div>
        <div class="stat-card stat-red">
          <div class="stat-icon"><i class="fas fa-times-circle"></i></div>
          <div class="stat-info">
            <h3><%= stats.unpaidThisMonth %></h3>
            <p>Hawajalipa</p>
          </div>
        </div>
        <div class="stat-card stat-yellow">
          <div class="stat-icon"><i class="fas fa-money-bill-wave"></i></div>
          <div class="stat-info">
            <h3>TZS <%= stats.totalRevenue.toLocaleString() %></h3>
            <p>Mapato Yote</p>
          </div>
        </div>
      </div>

      <!-- Recent Access Logs -->
      <div class="card mt-4">
        <div class="card-header">
          <h3><i class="fas fa-door-open"></i> Historia ya Hivi Karibuni ya Mlango</h3>
          <a href="/admin/access-logs" class="btn btn-sm btn-outline">Tazama Yote</a>
        </div>
        <div class="card-body">
          <table class="table">
            <thead>
              <tr><th>Wakati</th><th>Mpangaji</th><th>Chumba</th><th>Hatua</th><th>Hali</th></tr>
            </thead>
            <tbody>
              <% recentLogs.forEach(log => { %>
              <tr>
                <td><%= new Date(log.timestamp).toLocaleString('sw-TZ') %></td>
                <td><%= log.tenantId?.name || 'Haijulikani' %></td>
                <td><%= log.tenantId?.roomNo || '-' %></td>
                <td><%= log.deviceName %></td>
                <td>
                  <span class="badge badge-<%= log.action === 'access_granted' ? 'success' : 'danger' %>">
                    <%= log.action === 'access_granted' ? 'Ruhusiwa' : 'Katiwa' %>
                  </span>
                </td>
              </tr>
              <% }) %>
              <% if (recentLogs.length === 0) { %>
              <tr><td colspan="5" class="text-center text-muted">Hakuna historia bado</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="quick-actions mt-4">
        <h3>Vitendo vya Haraka</h3>
        <div class="quick-grid">
          <a href="/admin/tenants" class="quick-card">
            <i class="fas fa-user-plus"></i>
            <span>Ongeza Mpangaji</span>
          </a>
          <a href="/admin/payments" class="quick-card">
            <i class="fas fa-money-check-alt"></i>
            <span>Rekodi Malipo</span>
          </a>
          <a href="/admin/access-logs" class="quick-card">
            <i class="fas fa-history"></i>
            <span>Angalia Logs</span>
          </a>
          <button class="quick-card" onclick="setupAdmin()">
            <i class="fas fa-cog"></i>
            <span>Mipangilio</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <script src="/js/app.js"></script>
</body>
</html>
